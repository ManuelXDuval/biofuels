estimate_biomass <- function(replacement_pct = 1.0) {
# Constants
annual_petro_diesel_gal <- 57.5e9 # 57.5 Billion Gallons
energy_adj_factor <- 1.04         # RD energy density penalty
# Target RD needed (Adjusted for energy density)
target_rd_gal <- annual_petro_diesel_gal * replacement_pct * energy_adj_factor
# Conversion Yields
lbs_soy_per_gal <- 7.7
tons_wood_per_gal_diesel <- 1 / 44  # Based on ~44 gal diesel/dry ton
# Calculations
total_soy_oil_lbs <- target_rd_gal * lbs_soy_per_gal
total_woody_biomass_tons <- target_rd_gal * tons_wood_per_gal_diesel
# Contextual Stats (Approx)
us_soy_production_lbs <- 26e9  # Current US soy oil production
us_sustainable_biomass_tons <- 1e9 # "Billion Ton" report capacity
results <- list(
Target_Gallons_RD = target_rd_gal,
Soy_Option = list(
Lbs_Required = total_soy_oil_lbs,
Multiple_of_Current_US_Soy = total_soy_oil_lbs / us_soy_production_lbs
),
Woody_Option = list(
Tons_Required = total_woody_biomass_tons,
Pct_of_Total_US_Potential = (total_woody_biomass_tons / us_sustainable_biomass_tons) * 100
)
)
return(results)
}
# Example: What if we replace 100% of US Diesel?
full_replacement <- estimate_biomass(1.0)
print(full_replacement)
